generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceMemberRole {
  OWNER
  MEMBER
}

enum BoardMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum NotificationType {
  BOARD_INVITE
  CARD_ASSIGNED
  CARD_MOVED
  COMMENT_ADDED
  MEMBER_JOINED
  BOARD_UPDATED
}

enum ActivityType {
  CARD_CREATED
  CARD_MOVED
  CARD_UPDATED
  CARD_DELETED
  CARD_ASSIGNED
  CARD_UNASSIGNED
  COMMENT_ADDED
  COMMENT_DELETED
  LIST_CREATED
  LIST_RENAMED
  LIST_DELETED
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_REMOVED
  BOARD_UPDATED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  ownedWorkspaces      Workspace[]        @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  boardMemberships     BoardMember[]
  sentInvites          BoardInvite[]      @relation("InviteSender")
  cardAssignments      CardMember[]
  comments             Comment[]
  attachments          Attachment[]
  activities           Activity[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members WorkspaceMember[]
  boards  Board[]
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Board {
  id            String   @id @default(cuid())
  title         String
  description   String?
  backgroundUrl String?
  backgroundColor String?
  workspaceId   String
  createdAt     DateTime @default(now())

  workspace  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members    BoardMember[]
  invites    BoardInvite[]
  lists      List[]
  labels     Label[]
  activities Activity[]
}

model BoardMember {
  id      String          @id @default(cuid())
  boardId String
  userId  String
  role    BoardMemberRole @default(MEMBER)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model BoardInvite {
  id              String          @id @default(cuid())
  boardId         String
  invitedByUserId String
  invitedEmail    String
  token           String          @unique @default(cuid())
  role            BoardMemberRole @default(MEMBER)
  status          InviteStatus    @default(PENDING)
  expiresAt       DateTime
  createdAt       DateTime        @default(now())

  board         Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  invitedBy     User           @relation("InviteSender", fields: [invitedByUserId], references: [id])
  notifications Notification[]
}

model List {
  id          String   @id @default(cuid())
  title       String
  position    Float
  accentColor String?
  boardId     String
  createdAt   DateTime @default(now())

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]
}

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Float
  listId      String
  dueDate     DateTime?
  isDone      Boolean   @default(false)
  coverColor  String?
  createdAt   DateTime  @default(now())

  list          List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  members       CardMember[]
  labels        CardLabel[]
  comments      Comment[]
  attachments   Attachment[]
  notifications Notification[]
}

model CardMember {
  id     String @id @default(cuid())
  cardId String
  userId String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
}

model Label {
  id      String @id @default(cuid())
  name    String
  color   String
  boardId String

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]
}

model CardLabel {
  id      String @id @default(cuid())
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  cardId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  url          String
  publicId     String?
  cardId       String
  uploadedById String
  createdAt    DateTime @default(now())

  card       Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  payload   Json
  boardId   String
  userId    String
  createdAt DateTime     @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  type            NotificationType
  message         String
  isRead          Boolean          @default(false)
  relatedBoardId  String?
  relatedCardId   String?
  relatedInviteId String?
  createdAt       DateTime         @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedCard   Card?        @relation(fields: [relatedCardId], references: [id], onDelete: SetNull)
  relatedInvite BoardInvite? @relation(fields: [relatedInviteId], references: [id], onDelete: SetNull)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
